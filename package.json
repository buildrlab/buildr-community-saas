{
  "name": "buildrlab-community-saas",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r --topological build && pnpm -r --topological typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @buildrlab/web test:e2e",
    "format": "pnpm -r format"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.2.4",
    "globals": "^17.5.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.2"
  }
}
